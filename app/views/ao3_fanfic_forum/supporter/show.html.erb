<main class="ao3-supporter-page">
  <div class="ao3-supporter-page__shell">
    <header class="ao3-supporter-page__mast">
      <div class="ao3-supporter-page__copy">
        <a class="ao3-supporter-page__brand" href="<%= h @home_url %>">
          <%= I18n.t("ao3_fanfic.supporter_page.brand") %>
        </a>
        <h1><%= I18n.t("ao3_fanfic.supporter_page.title") %></h1>
        <p><%= I18n.t("ao3_fanfic.supporter_page.body") %></p>
      </div>

      <aside
        class="ao3-supporter-page__price"
        aria-label="<%= I18n.t("ao3_fanfic.supporter_page.price_label") %>"
      >
        <span><%= I18n.t("ao3_fanfic.supporter_page.price_prefix") %></span>
        <strong><%= h @price_label %></strong>
      </aside>
    </header>

    <section class="ao3-supporter-page__action" aria-labelledby="ao3-supporter-state-title">
      <div class="ao3-supporter-page__state">
        <h2 id="ao3-supporter-state-title"><%= I18n.t(@state_title_key) %></h2>
        <p><%= I18n.t(@state_body_key) %></p>
      </div>

      <div class="ao3-supporter-page__actions">
        <a class="btn btn-primary ao3-supporter-page__button" href="<%= h @primary_url %>">
          <%= I18n.t(@primary_label_key) %>
        </a>
        <a class="btn btn-default ao3-supporter-page__button" href="<%= h @secondary_url %>">
          <%= I18n.t(@secondary_label_key) %>
        </a>
      </div>
    </section>

    <section
      id="payment-methods"
      class="ao3-supporter-page__payments"
      aria-labelledby="ao3-supporter-payment-title"
    >
      <div class="ao3-supporter-page__payment-copy">
        <h2 id="ao3-supporter-payment-title">
          <%= I18n.t("ao3_fanfic.supporter_page.payments.title") %>
        </h2>
        <p><%= I18n.t("ao3_fanfic.supporter_page.payments.body") %></p>
      </div>

      <% if flash[:notice].present? || flash[:error].present? %>
        <div class="ao3-supporter-page__flash">
          <% if flash[:notice].present? %>
            <p><%= h flash[:notice] %></p>
          <% end %>
          <% if flash[:error].present? %>
            <p><%= h flash[:error] %></p>
          <% end %>
        </div>
      <% end %>

      <div class="ao3-supporter-page__payment-list">
        <article class="ao3-supporter-page__payment-method">
          <div class="ao3-supporter-page__payment-heading">
            <h3><%= I18n.t("ao3_fanfic.supporter_page.payments.stripe_title") %></h3>
            <span><%= I18n.t("ao3_fanfic.supporter_page.payments.automatic_badge") %></span>
          </div>
          <p><%= I18n.t("ao3_fanfic.supporter_page.payments.stripe_body") %></p>
          <% if @stripe_checkout_url.present? %>
            <a
              class="btn btn-primary ao3-supporter-page__button"
              href="<%= h @stripe_checkout_url %>"
            >
              <%= I18n.t("ao3_fanfic.supporter_page.payments.stripe_cta") %>
            </a>
          <% else %>
            <p class="ao3-supporter-page__payment-note">
              <%= I18n.t("ao3_fanfic.supporter_page.payments.stripe_unavailable") %>
            </p>
          <% end %>
        </article>

        <% @crypto_payment_methods.each do |method| %>
          <article class="ao3-supporter-page__payment-method">
            <div class="ao3-supporter-page__payment-heading">
              <h3><%= I18n.t(method[:name_key]) %></h3>
              <span><%= I18n.t(method[:network_key]) %></span>
            </div>
            <p>
              <%= I18n.t("ao3_fanfic.supporter_page.payments.crypto_body", code: method[:code]) %>
            </p>
            <label class="ao3-supporter-page__address">
              <span>
                <%= I18n.t("ao3_fanfic.supporter_page.payments.address_label", code: method[:code]) %>
              </span>
              <code><%= h method[:address] %></code>
            </label>

            <% if @signed_in %>
              <form
                action="<%= h @crypto_receipt_url %>"
                method="post"
                class="ao3-supporter-page__crypto-form"
              >
                <input
                  type="hidden"
                  name="authenticity_token"
                  value="<%= h form_authenticity_token %>"
                >
                <input
                  type="hidden"
                  name="crypto_payment[currency]"
                  value="<%= h method[:key] %>"
                >
                <label>
                  <span>
                    <%= I18n.t("ao3_fanfic.supporter_page.payments.transaction_label") %>
                  </span>
                  <input
                    type="text"
                    name="crypto_payment[transaction_id]"
                    required
                    maxlength="200"
                    autocomplete="off"
                  >
                </label>
                <label>
                  <span>
                    <%= I18n.t("ao3_fanfic.supporter_page.payments.amount_label") %>
                  </span>
                  <input
                    type="text"
                    name="crypto_payment[amount_note]"
                    maxlength="140"
                    autocomplete="off"
                  >
                </label>
                <button class="btn btn-default ao3-supporter-page__button" type="submit">
                  <%= I18n.t("ao3_fanfic.supporter_page.payments.crypto_cta") %>
                </button>
              </form>
            <% else %>
              <p class="ao3-supporter-page__payment-note">
                <%= I18n.t("ao3_fanfic.supporter_page.payments.crypto_login_note") %>
              </p>
            <% end %>
          </article>
        <% end %>

        <% if @crypto_payment_methods.blank? %>
          <article class="ao3-supporter-page__payment-method">
            <div class="ao3-supporter-page__payment-heading">
              <h3><%= I18n.t("ao3_fanfic.supporter_page.payments.crypto_title") %></h3>
              <span><%= I18n.t("ao3_fanfic.supporter_page.payments.manual_badge") %></span>
            </div>
            <p class="ao3-supporter-page__payment-note">
              <%= I18n.t("ao3_fanfic.supporter_page.payments.crypto_unavailable") %>
            </p>
          </article>
        <% end %>
      </div>

      <% if !@payment_methods_configured %>
        <p class="ao3-supporter-page__payment-note">
          <%= I18n.t("ao3_fanfic.supporter_page.payments.none_configured") %>
        </p>
      <% end %>
    </section>

    <section
      class="ao3-supporter-page__details"
      aria-label="<%= I18n.t("ao3_fanfic.supporter_page.details_label") %>"
    >
      <div class="ao3-supporter-page__benefits">
        <h2><%= I18n.t("ao3_fanfic.supporter_page.benefits_title") %></h2>
        <ul>
          <% I18n.t("ao3_fanfic.supporter_page.benefits").each do |benefit| %>
            <li><%= benefit %></li>
          <% end %>
        </ul>
      </div>

      <div class="ao3-supporter-page__access">
        <h2><%= I18n.t("ao3_fanfic.supporter_page.access_title") %></h2>
        <ol>
          <% I18n.t("ao3_fanfic.supporter_page.access_steps").each do |step| %>
            <li><%= step %></li>
          <% end %>
        </ol>
      </div>
    </section>

    <footer class="ao3-supporter-page__footer">
      <p><%= I18n.t("ao3_fanfic.supporter_page.footer") %></p>
    </footer>
  </div>
</main>
